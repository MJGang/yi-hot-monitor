# Database (MySQL)
# 格式: mysql+aiomysql://用户名:密码@主机:端口/数据库名
# 示例: mysql+aiomysql://root:password@localhost:3306/hotspot_db
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/hotspot_db

# Redis
# 格式: redis://主机:端口/数据库编号
# Docker 环境: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# AI Analysis (至少需要配置一个)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Twitter API (twitterapi.io) - 用于抓取 Twitter 热点
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_BASE=https://api.twitterapi.io

# Email Notification (可选)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=notify@example.com

# Server
HOST=0.0.0.0
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
